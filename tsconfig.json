{
  "compilerOptions": {
    "module": "nodenext",
    "target": "esnext",
    "types": [],
    
    // Explicit Production File Layout Boundaries
    "rootDir": "./src",
    "outDir": "./dist",

    // Other Outputs
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    // Stricter Typechecking Options
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    // Recommended Standard Options
    "strict": true,
    "jsx": "react-jsx",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true
  },
  
  // Direct compiler attention exclusively to core backend modules
  "include": [
    "src/**/*"
  ],
  
  // Isolate development scripts, test runners, and output builds out of compiler chains
  "exclude": [
    "node_modules",
    "dist",
    "prisma",
    "src/test/**/*"
  ]
}